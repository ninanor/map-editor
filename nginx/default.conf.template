upstream titiler_upstream {
    server titiler:80;
}

server {
    listen       80;
    server_name  localhost;
    root   /var/www;

    location / {
        try_files $uri /index.html;
    }

    location /titiler/ {
        proxy_pass http://titiler_upstream;
    }

    error_page   500 502 503 504  /50x.html;
    location = /50x.html {
        root   /usr/share/nginx/html;
    }
}

