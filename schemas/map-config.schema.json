        "type": "string"
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "titiler_api_url": {
          "type": "string"
        },
        "theme": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "footer": {
          "type": "object",
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "justify": {
              "type": "string",
              "enum": [
                "justify-center-safe",
                "justify-start",
                "justify-end-safe",
                "justify-between",
                "justify-normal",
                "justify-stretch"
              ]
            },
            "align": {
              "type": "string",
              "enum": [
                "items-center",
                "items-start",
                "items-end",
                "items-baseline"
              ]
            }
          },
          "required": [
            "items"
          ],
          "additionalProperties": false
        },
        "menuOrientation": {
          "type": "string",
          "enum": [
            "horizontal",
            "vertical"
          ]
        },
        "exclusiveLayers": {
          "type": "boolean"
        }
      },
      "required": [
        "titiler_api_url",
        "theme",
        "language"
      ],
      "additionalProperties": false
