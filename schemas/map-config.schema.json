                            "required": [
                              "url"
                            ],
                            "additionalProperties": false
                          },
                          "style": {
                            "type": "object",
                            "properties": {
                              "fillColor": {
                                "type": "string"
                              },
                              "lineColor": {
                                "type": "string"
                              },
                              "opacity": {
                                "type": "number",
                                "minimum": 0,
                                "maximum": 1
                              },
                              "lineWidth": {
                                "type": "number"
                              },
                              "pointRadius": {
                                "type": "number"
                              }
                            },
                            "additionalProperties": false
                          }
                        },
                        "required": [
                          "type",
                          "parquet"
                        ],
                        "additionalProperties": {}
                      },
                      {
                        "type": "object",
                        "propertyNames": {
                          "type": "string"
                        },
                        "additionalProperties": {}
                      }
                    ]
                  },
                  "download_url": {
                    "type": "string"
