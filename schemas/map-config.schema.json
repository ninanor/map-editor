                                        "additionalProperties": false
                                      },
                                      "field": {
                                        "type": "string"
                                      },
                                      "values": {
                                        "type": "array",
                                        "items": {
                                          "type": "object",
                                          "properties": {
                                            "value": {
                                              "type": "string"
                                            },
                                            "description": {
                                              "type": "string"
                                            },
                                            "color": {
                                              "type": "string"
                                            },
                                            "opacity": {
                                              "type": "number"
                                            },
                                            "width": {
                                              "type": "number"
                                            },
                                            "dasharray": {
                                              "type": "array",
                                              "items": {
                                                "type": "number"
                                              }
                                            }
                                          },
                                          "required": [
                                            "value",
                                            "color"
                                          ],
                                          "additionalProperties": false
                                        }
                                      }
                                    },
                                    "additionalProperties": false
