                                      "default": {
                                        "type": "object",
                                        "properties": {
                                          "description": {
                                            "type": "string"
                                          },
                                          "color": {
                                            "type": "string"
                                          },
                                          "opacity": {
                                            "type": "number"
                                          },
                                          "radius": {
                                            "type": "number"
