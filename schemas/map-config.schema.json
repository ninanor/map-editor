                                            "strokeWidth": {
                                              "type": "number"
                                            }
                                          },
                                          "required": [
                                            "value",
                                            "color"
                                          ],
                                          "additionalProperties": false
                                        }
                                      }
                                    },
                                    "additionalProperties": false
                                  }
                                },
                                "required": [
                                  "type",
                                  "source-layer"
