                                        "additionalProperties": false
                                      },
                                      "field": {
                                        "type": "string"
                                      },
                                      "values": {
                                        "type": "array",
                                        "items": {
                                          "type": "object",
                                          "properties": {
                                            "value": {
                                              "type": "string"
                                            },
                                            "description": {
                                              "type": "string"
                                            },
                                            "color": {
                                              "type": "string"
                                            },
                                            "borderColor": {
                                              "type": "string"
                                            },
                                            "opacity": {
                                              "type": "number"
                                            }
