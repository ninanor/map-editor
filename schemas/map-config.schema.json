                                            "type": "string"
                                          },
                                          "color": {
                                            "type": "string"
                                          },
                                          "opacity": {
                                            "type": "number"
                                          },
                                          "width": {
                                            "type": "number"
                                          },
                                          "dasharray": {
                                            "type": "array",
