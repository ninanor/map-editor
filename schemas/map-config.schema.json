  "title": "Map Configuration Schema",
  "description": "Schema for nina-maps map configuration",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "subtitle": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "icon": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "baseMap": {
      "type": "string"
    },
    "styles": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "layerOrder": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "viewState": {
      "type": "object",
